{
  "$schema": "https://schemas.aitc.io/v1",
  "version": "1.0.0",
  "description": "AITC V1 canonical entity schemas. All timestamps are UTC ISO 8601 strings. All IDs are UUID v4 strings unless otherwise noted.",
  "entities": {
    "Identity": {
      "description": "Canonical cross-source identity record. Every other entity references an Identity.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "AITC-generated canonical identity ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "required": true,
          "description": "Normalized (lowercased) primary email address"
        },
        "displayName": {
          "type": "string",
          "required": true,
          "description": "Human-readable display name"
        },
        "accountType": {
          "type": "string",
          "required": true,
          "enum": ["human", "service", "shared"],
          "description": "Classification of the identity"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["active", "suspended", "deprovisioned"],
          "description": "Current lifecycle status"
        },
        "externalIds": {
          "type": "object",
          "required": true,
          "description": "Map of source system name to source-system-specific ID",
          "example": { "okta": "00u1ab2cd3EF4GH5IJ6K7", "aad": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" }
        },
        "department": {
          "type": "string",
          "required": false,
          "description": "Organizational department"
        },
        "jobTitle": {
          "type": "string",
          "required": false,
          "description": "Job title"
        },
        "manager": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "Identity.id of the manager"
        },
        "riskTier": {
          "type": "string",
          "required": false,
          "enum": ["low", "medium", "high", "critical"],
          "description": "Derived risk classification based on CAS history"
        },
        "currentCas": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "required": false,
          "description": "Latest Continuous Authentication Score (0 = lowest risk, 100 = highest risk)"
        },
        "casUpdatedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp when CAS was last computed"
        },
        "learningModeUntil": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "Learning mode expiry timestamp. Autopilot is enabled after this time."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "required": false,
          "description": "Free-form tags (e.g., executive, privileged)"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "UTC timestamp when AITC first created this identity record"
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "UTC timestamp of most recent update"
        }
      }
    },
    "Session": {
      "description": "A single authenticated session for an identity.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "AITC session ID"
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id"
        },
        "sourceSessionId": {
          "type": "string",
          "required": true,
          "description": "Session ID from source system (e.g., Okta session ID)"
        },
        "source": {
          "type": "string",
          "required": true,
          "enum": ["okta", "m365"],
          "description": "Source system that owns this session"
        },
        "startedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "Session start time from auth event"
        },
        "endedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "Session end time; null if active"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["active", "revoked", "expired", "closed"],
          "description": "Current session status"
        },
        "ipAddress": {
          "type": "string",
          "required": true,
          "description": "IP address at session start"
        },
        "geoCountry": {
          "type": "string",
          "required": false,
          "description": "ISO 3166-1 alpha-2 country code"
        },
        "geoCity": {
          "type": "string",
          "required": false,
          "description": "City (best-effort geo lookup)"
        },
        "userAgent": {
          "type": "string",
          "required": false,
          "description": "User-agent string at session start"
        },
        "deviceId": {
          "type": "string",
          "required": false,
          "description": "Device fingerprint or managed device ID"
        },
        "authProtocol": {
          "type": "string",
          "required": false,
          "enum": ["saml", "oidc", "oauth2", "legacy"],
          "description": "Authentication protocol used"
        },
        "mfaSatisfied": {
          "type": "boolean",
          "required": false,
          "description": "Whether MFA was satisfied during authentication"
        },
        "riskAtStart": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "required": false,
          "description": "CAS score at the time the session was started"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        }
      }
    },
    "Event": {
      "description": "A normalized, immutable record of something that happened. Append-only.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "AITC event ID"
        },
        "sourceEventId": {
          "type": "string",
          "required": true,
          "description": "Original event ID from source system; used for deduplication"
        },
        "source": {
          "type": "string",
          "required": true,
          "enum": ["okta", "m365", "aitc"],
          "description": "Source system or 'aitc' for AITC-derived events"
        },
        "eventType": {
          "type": "string",
          "required": true,
          "description": "Canonical AITC event type (see events.md)"
        },
        "eventCategory": {
          "type": "string",
          "required": true,
          "enum": ["auth", "admin_change", "saas_action", "oauth_grant", "mailbox_rule", "file_access", "other"],
          "description": "High-level event category"
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id (resolved actor)"
        },
        "sessionId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Session.id if applicable"
        },
        "targetIdentityId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Identity.id if event targets another identity"
        },
        "targetResourceType": {
          "type": "string",
          "required": false,
          "description": "Type of resource acted upon (e.g., mailbox, file, group, policy)"
        },
        "targetResourceId": {
          "type": "string",
          "required": false,
          "description": "ID of the resource acted upon"
        },
        "outcome": {
          "type": "string",
          "required": true,
          "enum": ["success", "failure", "unknown"],
          "description": "Outcome of the event"
        },
        "severity": {
          "type": "string",
          "required": false,
          "enum": ["info", "low", "medium", "high", "critical"],
          "description": "Normalized severity set by normalization rules"
        },
        "ipAddress": {
          "type": "string",
          "required": false,
          "description": "Source IP of the actor"
        },
        "geoCountry": {
          "type": "string",
          "required": false,
          "description": "ISO 3166-1 alpha-2 country code"
        },
        "userAgent": {
          "type": "string",
          "required": false,
          "description": "User-agent string"
        },
        "raw": {
          "type": "object",
          "required": true,
          "description": "Original source event payload preserved for auditability; never used in risk scoring"
        },
        "occurredAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "Time the event occurred at the source system"
        },
        "ingestedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "Time AITC received and stored the event"
        },
        "normalizedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "Time normalization completed"
        }
      }
    },
    "RiskSignal": {
      "description": "A scored anomaly detection output from the Risk Engine.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id"
        },
        "sessionId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Session.id if session-scoped"
        },
        "triggerEventId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Event.id that triggered this signal"
        },
        "signalType": {
          "type": "string",
          "required": true,
          "description": "Detection rule or model ID",
          "examples": ["impossible_travel", "new_country_login", "mfa_fatigue", "bulk_download", "privileged_role_assigned", "oauth_scope_escalation"]
        },
        "casScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "required": true,
          "description": "CAS score at time of signal generation"
        },
        "casDelta": {
          "type": "number",
          "required": true,
          "description": "Change in CAS from previous score (positive = increased risk)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "required": true,
          "description": "Model confidence score (0 = no confidence, 1 = certain)"
        },
        "severity": {
          "type": "string",
          "required": true,
          "enum": ["low", "medium", "high", "critical"],
          "description": "Severity of the anomaly"
        },
        "explanation": {
          "type": "string",
          "required": false,
          "description": "Human-readable explanation of the anomaly"
        },
        "featureSnapshot": {
          "type": "object",
          "required": false,
          "description": "Feature values at time of scoring (for auditability and model debugging)"
        },
        "caseId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Case.id once grouped into a case"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["open", "grouped", "closed", "false_positive"],
          "description": "Lifecycle status of the signal"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        }
      }
    },
    "Case": {
      "description": "An investigation record grouping related RiskSignals and tracking the response lifecycle.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id (primary subject of this case)"
        },
        "title": {
          "type": "string",
          "required": true,
          "description": "Human-readable case title"
        },
        "summary": {
          "type": "string",
          "required": false,
          "description": "LLM-generated narrative summary (bounded; cannot trigger actions)"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["open", "in_progress", "resolved", "false_positive", "escalated"],
          "description": "Current case status"
        },
        "severity": {
          "type": "string",
          "required": true,
          "enum": ["low", "medium", "high", "critical"],
          "description": "Derived from the highest RiskSignal severity in this case"
        },
        "riskSignalIds": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" },
          "required": true,
          "description": "List of FK → RiskSignal.id"
        },
        "responseActionIds": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" },
          "required": false,
          "description": "List of FK → ResponseAction.id"
        },
        "assignedTo": {
          "type": "string",
          "required": false,
          "description": "Analyst user ID, or 'autopilot' if handled autonomously"
        },
        "routingMode": {
          "type": "string",
          "required": true,
          "enum": ["human_review", "autopilot"],
          "description": "How this case is being handled"
        },
        "learningModeActive": {
          "type": "boolean",
          "required": true,
          "description": "Whether learning mode was active when the case was opened"
        },
        "recommendation": {
          "type": "string",
          "required": false,
          "description": "LLM-generated recommended next steps (bounded; read-only)"
        },
        "recommendedActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["session_revoke", "mfa_stepup", "conditional_access_update", "recommendation_only"]
          },
          "required": false,
          "description": "Allowlisted action types recommended by the risk engine"
        },
        "openedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "UTC timestamp when the case was opened"
        },
        "closedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp when the case was closed; null if open"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        }
      }
    },
    "ResponseAction": {
      "description": "An immutable audit record for every action proposed, validated, executed, or rejected. Never updated after creation.",
      "immutable": true,
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true
        },
        "caseId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Case.id"
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id (subject of the action)"
        },
        "actionType": {
          "type": "string",
          "required": true,
          "enum": ["session_revoke", "mfa_stepup", "conditional_access_update", "recommendation_only"],
          "description": "The type of action taken. Only allowlisted types are permitted."
        },
        "source": {
          "type": "string",
          "required": true,
          "enum": ["autopilot", "analyst"],
          "description": "What triggered this action"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["proposed", "validated", "executed", "rejected", "reverted"],
          "description": "Current status of the action"
        },
        "rejectionReason": {
          "type": "string",
          "required": false,
          "description": "Why the policy validator rejected the action (populated when status = rejected)"
        },
        "targetSessionId": {
          "type": "string",
          "format": "uuid",
          "required": false,
          "description": "FK → Session.id for session_revoke actions"
        },
        "policyChange": {
          "type": "object",
          "required": false,
          "description": "Structured description of the policy change applied (for conditional_access_update)"
        },
        "executedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp when action was executed at the target system"
        },
        "executionResult": {
          "type": "string",
          "required": false,
          "enum": ["ok", "error", "partial"],
          "description": "Result of execution at target system"
        },
        "executionError": {
          "type": "string",
          "required": false,
          "description": "Error detail if executionResult = error"
        },
        "revertedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp if the action was reverted"
        },
        "revertedBy": {
          "type": "string",
          "required": false,
          "description": "Analyst user ID who reverted the action"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "UTC timestamp when this record was created (immutable)"
        },
        "validatedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp when policy validator processed the action"
        }
      }
    },
    "OAuthApp": {
      "description": "An OAuth application granted access by an identity. Optional V1 entity for OAuth abuse detection.",
      "fields": {
        "id": {
          "type": "string",
          "format": "uuid",
          "required": true
        },
        "identityId": {
          "type": "string",
          "format": "uuid",
          "required": true,
          "description": "FK → Identity.id (who granted access)"
        },
        "appId": {
          "type": "string",
          "required": true,
          "description": "OAuth client ID from source system"
        },
        "appName": {
          "type": "string",
          "required": true,
          "description": "Display name of the OAuth application"
        },
        "source": {
          "type": "string",
          "required": true,
          "enum": ["okta", "m365"],
          "description": "Source system where the grant was recorded"
        },
        "scopes": {
          "type": "array",
          "items": { "type": "string" },
          "required": true,
          "description": "List of OAuth scopes granted"
        },
        "grantedAt": {
          "type": "string",
          "format": "datetime",
          "required": true,
          "description": "UTC timestamp when access was granted"
        },
        "revokedAt": {
          "type": "string",
          "format": "datetime",
          "required": false,
          "description": "UTC timestamp when access was revoked; null if still active"
        },
        "status": {
          "type": "string",
          "required": true,
          "enum": ["active", "revoked"],
          "description": "Current grant status"
        },
        "riskScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "required": false,
          "description": "Risk score for this grant (scope sensitivity × app trust)"
        },
        "createdAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        },
        "updatedAt": {
          "type": "string",
          "format": "datetime",
          "required": true
        }
      }
    }
  }
}
